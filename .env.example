# === Sujet de la veille ===
# Ce starter fonctionne pour n'importe quel sujet (IA, marketing, crypto,
# design, finance, lifestyle...). Choisis le tien ici.
# Si tu laisses ces 3 lignes commentées, le défaut est "IA".
#
# TOPIC_NAME=Marketing
# TOPIC_DESCRIPTION=marketing digital pour indépendants
# BRAND_NAME=Marketing Daily
#
# AUDIENCE_DESCRIPTION peut aussi être personnalisé (multi-ligne) — par défaut,
# le code génère une description générique calée sur ton TOPIC_DESCRIPTION.

# === API Keys principales ===
# Anthropic (Claude Sonnet 4.6) — scoring, éditorial, enrichissement
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# OpenAI (gpt-image-2) — génération des infographies
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Google (Gemini 3 Pro Image) — génération des slides du carrousel Instagram
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Notion ===
# 1. Créer une intégration : https://www.notion.so/profile/integrations
# 2. Partager TA database "Veille IA" avec cette intégration
# 3. Récupérer la database ID dans l'URL (les 32 caractères après ton-workspace/)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# === Sous-pages Notion (rapports automatiques mis à jour à chaque run) ===
# 1. ID de la page parente où seront créées les sous-pages "Coûts API" et
#    "Rapport quotidien" (ex: la page racine de ton espace "Veille IA")
NOTION_PARENT_PAGE_ID=

# 2. Lancer une fois en local : python setup_cost_report_page.py
#    Le script crée la sous-page et affiche son ID, à coller ci-dessous :
NOTION_COST_REPORT_PAGE_ID=

# 3. Lancer une fois en local : python setup_daily_report_page.py
#    Idem, copier l'ID retourné :
NOTION_DAILY_REPORT_PAGE_ID=

# === Reddit (optionnel) ===
# Créer une app sur https://www.reddit.com/prefs/apps (type: script)
# Si tu ne veux pas Reddit, laisse vide : la source sera désactivée
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=veille-ia-bot/1.0

# === Supabase (storage images + cache + logs API + rapports quotidiens) ===
# https://supabase.com → New project (gratuit), puis :
# - Settings → API : copier URL + service_role key
# - Storage → New bucket "veille-ia-images" (PUBLIC)
# - SQL editor : appliquer les 2 migrations dans observability/migrations/*.sql
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=veille-images

# === Gmail (optionnel — pour scanner les newsletters IA) ===
# Si tu n'utilises pas Gmail, laisse les paths par défaut, la source sera désactivée
GMAIL_TOKEN_PATH=./config/gmail_token.json
GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json
