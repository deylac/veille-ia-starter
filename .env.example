# === API Keys principales ===
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Notion ===
# Créer une intégration sur https://www.notion.so/profile/integrations
# Puis partager la database avec cette intégration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# === Reddit ===
# Créer une app sur https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=xxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
REDDIT_USER_AGENT=veille-ia-bot/1.0

# === Supabase (pour héberger les images) ===
# Créer un bucket public "veille-ia-images"
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_BUCKET=veille-ia-images

# === Gmail (pour les newsletters) ===
# Voir NOTION_SETUP.md pour la procédure OAuth
GMAIL_TOKEN_PATH=./config/gmail_token.json
GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json
